DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/barbershop
RETENTION_GUEST_MONTHS=12
RETENTION_CUSTOMER_MONTHS=12
# Required — backend refuses to start without it (protects the retention endpoint).
RETENTION_CRON_SECRET=generate_a_secure_random_string_here
# Logs every SQL query incl. bound parameters (may include customer PII). Local debugging only — never True in production.
SQL_ECHO=False

# Phase 1: Admin & Auth
JWT_SECRET_KEY=generate_a_secure_random_string_here
SESSION_EXPIRE_HOURS=8
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
RATE_LIMIT_LOGIN_PER_MINUTE=20
COOKIE_SECURE=False

# Phase 2 / Public booking settings
BREVO_API_KEY=
EMAIL_FROM=buchung@azzam-salon.de
EMAIL_FROM_NAME=Azzam Barbershop
EMAIL_REPLY_TO=Oazzam412@gmail.com
PUBLIC_BASE_URL=http://localhost:3000
BOOKING_MIN_LEAD_HOURS=2
BOOKING_MAX_HORIZON_DAYS=60
REMINDER_LEAD_HOURS=24
REMINDER_SCAN_INTERVAL_HOURS=1
CANCELLATION_CUTOFF_HOURS=24
RATE_LIMIT_BOOKING_PER_MINUTE=10
