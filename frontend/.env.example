# Backend-API-Basis-URL. Prod (Muster B, Same-Origin): RELATIV lassen, damit alle Calls
# same-origin über die eigene Domain laufen und der Next.js-Rewrite-Proxy sie ans Backend
# leitet. Wird zur BUILD-Zeit eingebacken (NEXT_PUBLIC_*), daher im Docker-Build als
# --build-arg / ARG setzen, nicht erst zur Laufzeit.
# Lokale Dev OHNE Proxy: auf absolute Backend-URL zeigen, z.B. http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# Interner Ziel-Host für den serverseitigen Rewrite-Proxy (next.config.ts rewrites())
# UND für serverseitige fetch()-Aufrufe in Server Components (lib/api.ts, apiBase()).
# Wird zur LAUFZEIT gelesen (echte Runtime-Env im Container setzen).
# Prod/Compose: http://backend:8000 (interner Compose-Netz-Name). Lokale Dev mit `next dev`
# gegen ein lokal laufendes Backend: http://localhost:8000
BACKEND_INTERNAL_URL=http://backend:8000

# WhatsApp Click-to-Chat number (format: country code without '+' or spaces, e.g., 491701234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=491701234567

# Social Media Links (reine Verlinkungen, keine Feeds/Skripte)
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/barbershop_cottbus
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@barbershop_cottbus

# Google-Bewertungen Links
# Direkter Link zum Google-Bewertungsformular ("Bewertung schreiben")
NEXT_PUBLIC_WRITE_REVIEW_URL=https://search.google.com/local/writereview?placeid=ChIJ81T_XXXXX
# Link zum Google-Maps-Profil des Salons
NEXT_PUBLIC_GOOGLE_PROFILE_URL=https://maps.google.com/?cid=12345678901234567890

# Salon Geo-Koordinaten (Cottbus)
NEXT_PUBLIC_GEO_LAT=51.75631
NEXT_PUBLIC_GEO_LNG=14.33286

# Google Maps Embed URL für den Iframe (geladen erst nach Einwilligung)
NEXT_PUBLIC_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2449.1234567890!2d14.33286!3d51.75631!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTHCsDQ1JzIyLjciTiAxNCsxOSc1OC4zIkU!5e0!3m2!1sde!2sde!4v1234567890123
